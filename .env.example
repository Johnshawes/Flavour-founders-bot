# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Instagram / Meta
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
APP_SECRET=your_instagram_app_secret_here
VERIFY_TOKEN=flavourfounders2024
INSTAGRAM_PAGE_ID=17841411627714313

# Supabase (same project as audit-generator)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Funnel URLs
LEAD_MAGNET_URL=https://ff-margin-calculator.vercel.app
AUDIT_PAYMENT_URL=https://whop.com/checkout/plan_2A9NPWYCBjKfR

# Admin endpoint key — used for /admin/* and the test_bot.py smoke tester
ADMIN_KEY=pick_any_long_random_string_here

# Whop webhook signing secret — copy from Whop dashboard -> Developer -> Webhooks
WHOP_WEBHOOK_SECRET=

# GHL handoff (Phase 2 — email-captured leads get pushed to GHL so workflows
# can run follow-ups 2 + 3 via email since IG can't reach them past Meta's
# 24h DM window). Same Private Integration key the GHL MCP uses is fine —
# Contacts scope must be enabled. Bot silently skips GHL push if either var
# is empty (Supabase email row still saved).
GHL_API_KEY=
GHL_LOCATION_ID=
# Optional override; defaults to https://services.leadconnectorhq.com
GHL_BASE_URL=

# (Used by test_bot.py to know where the bot is)
BOT_URL=https://web-production-3aebb.up.railway.app
